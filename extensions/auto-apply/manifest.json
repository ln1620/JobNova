{
  "manifest_version": 3,
  "name": "JobNova Auto Apply",
  "version": "4.1.0",
  "description": "Fills and submits Lever job applications on EC2.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*",
    "https://jobs.lever.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://jobs.lever.co/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "JobNova Auto Apply",
    "default_popup": "popup.html"
  }
}
